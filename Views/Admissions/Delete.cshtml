@model HospitalManagement.Models.Admission
@{
    ViewData["Title"] = "Delete Admission";
}

<div class="page-header">
    <h4 class="mb-0 fw-bold text-danger">Delete Admission</h4>
</div>

<div class="card border-danger border-0 shadow-sm" style="max-width:600px;">
    <div class="card-body">
        <h5 class="card-title">Are you sure you want to delete this admission?</h5>
        <p class="text-muted">This action cannot be undone.</p>
        
        <dl class="row">
            <dt class="col-sm-4">Admission ID</dt>
            <dd class="col-sm-8">@Model.AdmissionId</dd>
            <dt class="col-sm-4">Patient</dt>
            <dd class="col-sm-8">@Model.Patient?.FullName</dd>
            <dt class="col-sm-4">Doctor</dt>
            <dd class="col-sm-8">@Model.Doctor?.FullName</dd>
            <dt class="col-sm-4">Admission Date</dt>
            <dd class="col-sm-8">@Model.AdmissionDate.ToString("MMM dd, yyyy")</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.Status</dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="AdmissionId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
