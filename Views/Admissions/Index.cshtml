@model IEnumerable<HospitalManagement.Models.Admission>
@{
    ViewData["Title"] = "Admissions";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h4 class="mb-0 fw-bold">Admissions</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New Admission</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-2">
        <select name="status" class="form-select form-select-sm">
            <option value="">All Statuses</option>
            <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
            <option value="Discharged" selected="@(ViewBag.Status == "Discharged")">Discharged</option>
            <option value="Transferred" selected="@(ViewBag.Status == "Transferred")">Transferred</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="type" class="form-select form-select-sm">
            <option value="">All Types</option>
            <option value="Emergency" selected="@(ViewBag.Type == "Emergency")">Emergency</option>
            <option value="OPD" selected="@(ViewBag.Type == "OPD")">OPD</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="wardId" asp-items="ViewBag.Wards" class="form-select form-select-sm">
            <option value="">All Wards</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-warning">
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Ward</th>
                        <th>Bed</th>
                        <th>Type</th>
                        <th>Admitted</th>
                        <th>Exp. Discharge</th>
                        <th>Stay</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td>@a.AdmissionId</td>
                            <td class="fw-semibold">@a.Patient?.FullName</td>
                            <td class="small">@a.Doctor?.FullName</td>
                            <td class="small">@a.Ward?.Name</td>
                            <td><span class="badge bg-secondary">@a.Bed?.BedNumber</span></td>
                            <td>
                                <span class="badge @(a.AdmissionType=="Emergency"?"bg-danger":"bg-primary")">
                                    @a.AdmissionType
                                </span>
                            </td>
                            <td class="small">@a.AdmissionDate.ToString("dd MMM yy HH:mm")</td>
                            <td class="small">@(a.ExpectedDischargeDate?.ToString("dd MMM yy") ?? "—")</td>
                            <td class="small">@a.StayDuration d</td>
                            <td>
                                <span class="badge @(a.Status=="Active"?"bg-success":a.Status=="Discharged"?"bg-secondary":"bg-warning text-dark")">
                                    @a.Status
                                </span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@a.AdmissionId" class="btn btn-outline-info btn-sm">View</a>
                                @if (a.Status == "Active")
                                {
                                    <a asp-action="Discharge" asp-route-id="@a.AdmissionId" class="btn btn-outline-success btn-sm">Discharge</a>
                                }
                                <a asp-action="Edit" asp-route-id="@a.AdmissionId" class="btn btn-outline-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@a.AdmissionId" class="btn btn-outline-danger btn-sm">Del</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="11" class="text-center text-muted py-4">No admissions found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
