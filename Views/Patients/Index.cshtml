@model IEnumerable<HospitalManagement.Models.Patient>
@{
    ViewData["Title"] = "Patients";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h4 class="mb-0 fw-bold">Patients</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Register Patient</a>
</div>

<!-- Filters -->
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Search name or phone..." />
    </div>
    <div class="col-md-2">
        <select name="gender" class="form-select form-select-sm">
            <option value="">All Genders</option>
            <option value="Male" selected="@(ViewBag.Gender == "Male")">Male</option>
            <option value="Female" selected="@(ViewBag.Gender == "Female")">Female</option>
            <option value="Other" selected="@(ViewBag.Gender == "Other")">Other</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="blood" class="form-select form-select-sm">
            <option value="">All Blood Groups</option>
            @foreach (var bg in new[]{"A+","A-","B+","B-","AB+","AB-","O+","O-"})
            {
                <option value="@bg" selected="@(ViewBag.Blood == bg)">@bg</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Age / Gender</th>
                        <th>Blood</th>
                        <th>Phone</th>
                        <th>Medical History</th>
                        <th>Registered</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.PatientId</td>
                            <td class="fw-semibold">@p.FullName</td>
                            <td>@p.Age yrs / @p.Gender</td>
                            <td><span class="badge bg-danger">@p.BloodGroup</span></td>
                            <td>@p.PhoneNumber</td>
                            <td class="text-muted small" style="max-width:180px;">@(p.MedicalHistory?.Length > 40 ? p.MedicalHistory.Substring(0, 40) + "..." : p.MedicalHistory ?? "—")</td>
                            <td class="small">@p.RegistrationDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@p.PatientId" class="btn btn-outline-info btn-xs btn-sm">View</a>
                                <a asp-action="Edit" asp-route-id="@p.PatientId" class="btn btn-outline-warning btn-sm">Edit</a>
                                <a asp-controller="Admissions" asp-action="Create" asp-route-patientId="@p.PatientId" class="btn btn-outline-success btn-sm">Admit</a>
                                <a asp-action="Delete" asp-route-id="@p.PatientId" class="btn btn-outline-danger btn-sm">Del</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No patients found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
