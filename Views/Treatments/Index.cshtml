@model IEnumerable<HospitalManagement.Models.Treatment>
@{
    ViewData["Title"] = "Treatments";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h4 class="mb-0 fw-bold">Treatments</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Treatment</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Treatment Name</th>
                        <th>Type</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Cost</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TreatmentId</td>
                            <td>
                                <strong>@item.TreatmentName</strong>
                                <br><small class="text-muted">@item.Description.Substring(0, Math.Min(item.Description.Length, 50))...</small>
                            </td>
                            <td><span class="badge bg-info">@item.TreatmentType</span></td>
                            <td>@item.Doctor?.FullName</td>
                            <td>@item.TreatmentDate.ToString("MMM dd, yyyy")</td>
                            <td>@item.Cost.ToString("C")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.TreatmentId" class="btn btn-sm btn-outline-primary">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.TreatmentId" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.TreatmentId" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-3">No treatments recorded yet</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
